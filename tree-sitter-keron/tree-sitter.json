{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "keron",
      "camelcase": "Keron",
      "title": "keron",
      "scope": "source.keron",
      "path": ".",
      "file-types": [
        "keron"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^keron$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the keron dotfile-manager language",
    "authors": [
      {
        "name": "Stefan Ruzitschka",
        "email": "stefan@icepuma.dev"
      }
    ],
    "links": {
      "repository": "https://github.com/icepuma/keron"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
