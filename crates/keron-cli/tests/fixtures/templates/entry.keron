# Template manifest used by the cross-platform e2e suite. Renders
# `greeting.tpl` (two `{{ ... }}` Tera placeholders) into a file
# under the test's fake `$HOME`. Pins template render + write +
# idempotency end-to-end through the `keron` CLI.
val home: String = env("HOME") ?? keron_root()

reconcile template(
  source = "./greeting.tpl",
  target = "${home}/.testgreeting",
  vars = {"name": "keron", "scope": "e2e"},
)
