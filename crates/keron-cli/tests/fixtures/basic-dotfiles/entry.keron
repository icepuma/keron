# Realistic dotfiles manifest used by the cross-platform e2e suite.
# Targets resolve to `$HOME/...` (the test sets HOME to a fresh
# tempdir per run); sources resolve relative to this `.keron` file
# (which keron canonicalizes inside the keron root).
val home: String = env("HOME") ?? keron_root()

reconcile {
  symlink(source = "./zshrc", target = "${home}/.testrc")
  symlink(source = "./gitconfig", target = "${home}/.testgitconfig")
  symlink(source = "./vimrc", target = "${home}/.testvimrc")
  symlink(source = "./config/nvim/init.lua", target = "${home}/.config/keron-e2e/nvim/init.lua")
}
