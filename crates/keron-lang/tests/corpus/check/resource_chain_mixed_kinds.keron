
val zshrc: Symlink = symlink(source = "~/.zshrc", target = "df/zshrc")
val motd: Template = template(source = "tmpl.tpl", target = "/etc/motd", vars = {"body": "welcome"})
val issue: Template = template(source = "tmpl.tpl", target = "/etc/issue", vars = {"body": "welcome"})

reconcile issue -> motd -> zshrc
