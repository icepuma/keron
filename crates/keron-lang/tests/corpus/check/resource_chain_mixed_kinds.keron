
val zshrc: Symlink = symlink(from = "df/zshrc", to = "~/.zshrc")
val motd: Template = template(path = "/etc/motd", source = "tmpl.tpl", vars = {"body": "welcome"})
val issue: Template = template(path = "/etc/issue", source = "tmpl.tpl", vars = {"body": "welcome"})

reconcile issue -> motd -> zshrc
