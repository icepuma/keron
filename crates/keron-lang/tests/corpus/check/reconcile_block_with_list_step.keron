val a: Symlink = symlink(source = "~/.a", target = "df/a")

val b: Symlink = symlink(source = "~/.b", target = "df/b")

val c: Symlink = symlink(source = "~/.c", target = "df/c")

val shells: List<Symlink> = [
  symlink(source = "~/.zshrc", target = "df/zsh"),
  symlink(source = "~/.bashrc", target = "df/bash"),
]

reconcile {
  [a, b];
  shells;
  c;
}
