from "std:fs" use symlink, file, directory, Symlink, File, Directory, Resource

val zshrc: Symlink = symlink(from = "df/zshrc", to = "~/.zshrc")
val motd: File = file(path = "/etc/motd", content = "welcome")
val data: Directory = directory(path = "~/data")

val mixed: List<Resource> = [zshrc, motd, data]

reconcile mixed
