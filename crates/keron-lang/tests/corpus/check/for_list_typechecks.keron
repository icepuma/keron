
# `for x in xs` over a `List<T>` binds `x: T` in body scope.

fn link(name: String): Symlink {
  symlink(from = "~/dotfiles/${name}", to = "~/.${name}")
}

val dotfiles: List<String> = ["zshrc", "vimrc", "tmux.conf"]

# Loop variable is `String`, used inside the body to call `link`.
for name in dotfiles {
  reconcile link(name)
}

# Body may contain inner `if` whose branches are also `Void`.
val flags: List<Boolean> = [true, false, true]
for f in flags {
  if f { reconcile link("bashrc") }
}

# Inner `val` referencing the loop binding.
val seeds: List<Int> = [1, 2]
for s in seeds {
  val tag: String = "seed-${s}"
  reconcile link(tag)
}
