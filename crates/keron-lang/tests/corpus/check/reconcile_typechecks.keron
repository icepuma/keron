
val zshrc: Symlink = symlink(source = "~/.zshrc", target = "~/df/zshrc")
val gitcfg: Template = template(source = "tmpl.tpl", target = "~/.gitconfig", vars = {"body": "[user]"})

reconcile zshrc
reconcile gitcfg

reconcile [
  symlink(source = "~/.vimrc", target = "~/df/vimrc"),
  symlink(source = "~/.tmux.conf", target = "~/df/tmux.conf"),
]
