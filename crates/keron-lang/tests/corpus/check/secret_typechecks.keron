# `Secret` is a marker type: it can be constructed by `secret(uri)`,
# moved through fn parameters, equality-compared with another secret,
# and unwrapped to a `String` exactly once per call site. It is **not**
# interpolatable, concatenable, or cross-comparable with `String`.
val gh: Secret = secret("op://vault/github/token")

val npm: Secret = secret("op://vault/npm/token")

# Equality is the only legal binop between two `Secret`s. The result
# is `Boolean`, so it composes with `if`.
val same: Boolean = gh == npm

val differ: Boolean = gh != npm

# A function may take and return `Secret`s — useful for routing without
# unwrapping.
fn pick_token(prefer_npm: Boolean): Secret {
  if prefer_npm {
    npm
  } else {
    gh
  }
}

val chosen: Secret = pick_token(false)

# `unwrap_secret(s)` is the one legal exit. Each call site is the
# audit point where the value becomes plain text.
val rendered: String = unwrap_secret(chosen)

val gh_plain: String = unwrap_secret(gh)

# Once unwrapped, the value behaves like any other `String` — it
# concats, interpolates, and flows into resource arguments.
val auth_header: String = "Authorization: Bearer " + gh_plain

val composed: String = "token=${rendered}"

# `Map<String, Secret>` is allowed (only the *key* type is restricted;
# values can be any type).
val tokens: Map<String, Secret> = {"github": gh, "npm": npm}
