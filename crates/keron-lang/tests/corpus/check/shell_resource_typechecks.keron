val default_kind: ShellKind = "sh"

val refresh: Shell = shell(
  kind = default_kind,
  name = "refresh-font-cache",
  script = "fc-cache -f \"$HOME/.local/share/fonts\"\n",
)

val any_shell: Resource = refresh

val mixed: List<Resource> = [
  refresh,
  symlink(source = "~/.zshrc", target = "~/dotfiles/zshrc"),
  template(source = "tmpl.tpl", target = "~/.config/example", vars = {"body": "ok"}),
  brew("ripgrep"),
]

reconcile refresh -> any_shell

reconcile mixed
