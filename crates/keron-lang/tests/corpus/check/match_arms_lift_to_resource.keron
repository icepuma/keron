type Kind = "link" | "tmpl"

# Arms returning different resource singletons (`Symlink`, `Template`)
# lift to `Resource`, mirroring the list-inference rule.
fn make(k: Kind): Resource {
  match k {
    "link" => symlink(source = "b", target = "a"),
    "tmpl" => template(source = "t.tpl", target = "p", vars = {}),
  }
}
