# `os_type()` and `os_arch()` each return a fixed string-union type.
# Exhaustive `match` over every variant is legal without a wildcard
# (the union closes the domain). Equality with a literal variant is
# also legal because a `StringUnion` is comparable with `String` and
# with itself.

val host: OsType = os_type()
val arch: OsArch = os_arch()

val label: String = match host {
  "Linux"   => "linux box",
  "Macos"   => "mac",
  "Windows" => "windows box",
  "Unknown" => "?",
}

val arch_label: String = match arch {
  "x86_64"  => "amd64",
  "aarch64" => "arm64",
  "arm"     => "armv7",
  "x86"     => "i686",
  "Unknown" => "?",
}

# Literal equality drives an `if`, no `match` required.
val is_mac: Boolean = host == "Macos"
val tier: String = if arch == "aarch64" {
  "fast"
} else if arch == "x86_64" {
  "normal"
} else {
  "exotic"
}

# A union variant is assignable to a `String` slot via concat /
# interpolation, since `StringUnion <: String` at use sites.
val summary: String = "${host}/${arch}"
