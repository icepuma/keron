# Guards are `Boolean` expressions evaluated after the pattern binds.
# A guarded arm does NOT close exhaustiveness — a trailing unguarded
# arm (catch-all here) is still required.
val verdict: String = match os_type() {
  "Macos" if os_arch() == "aarch64" => "macos-arm",
  "Macos" => "macos-intel",
  "Linux" => "linux",
  _ => "other",
}

# A guarded `_` is fine but doesn't make subsequent arms unreachable.
val tier: String = match os_type() {
  _ if os_arch() == "aarch64" => "arm",
  _ => "anything",
}
